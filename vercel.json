{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/publico", "destination": "/publico.html" },
    { "source": "/tv", "destination": "/tv.html" },
    { "source": "/planillero", "destination": "/planillero.html" },
    { "source": "/fixture", "destination": "/fixture.html" },
    { "source": "/ranking", "destination": "/ranking.html" },
    { "source": "/accesos", "destination": "/accesos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" }
      ]
    }
  ]
}
